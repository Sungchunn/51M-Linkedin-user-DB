# ==================== PRODUCTION ENVIRONMENT ====================
# Copy this to .env for production deployment
# DO NOT commit actual secrets to git!

# ==================== DATABASE ====================
# Production database URL (provided by Railway/Render/Fly.io)
DATABASE_URL=${DATABASE_URL}
PG_DSN=${DATABASE_URL}

# Connection Pool Settings (adjust based on your database plan)
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_TIMEOUT=10

# ==================== EMBEDDING SERVICE ====================
OPENAI_API_KEY=your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Embedding Generation Settings
MIN_QUALITY_SCORE=0.7
MAX_TEXT_LENGTH=8000
BATCH_SIZE_IO=5000
BATCH_SIZE_EMBED=100

# ==================== API CONFIGURATION ====================
API_HOST=0.0.0.0
API_PORT=${PORT:-8000}
API_WORKERS=4
API_RELOAD=false

# CORS Settings (comma-separated origins - ADD YOUR PRODUCTION DOMAIN)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
# Allow all origins regex (tighten for production)
CORS_ORIGIN_REGEX=https?://.*\.your-domain\.com$

# ==================== REDIS ====================
# Production Redis URL (if using managed Redis)
REDIS_URL=${REDIS_URL}
REDIS_ENABLED=true
REDIS_HOST=${REDIS_HOST:-localhost}
REDIS_PORT=${REDIS_PORT:-6379}
REDIS_DB=0
REDIS_PASSWORD=${REDIS_PASSWORD}

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================== PERFORMANCE ====================
# HNSW Index Parameters
HNSW_M=16
HNSW_EF_CONSTRUCTION=64
HNSW_EF_SEARCH=64

# Hybrid Search Weights
VECTOR_WEIGHT=0.8
LEXICAL_WEIGHT=0.2

# ==================== PRODUCTION FLAGS ====================
DEBUG=false
TESTING=false
ENVIRONMENT=production

# ==================== AUTHENTICATION ====================
# JWT Secret Key - MUST GENERATE WITH: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE-THIS-TO-SECURE-RANDOM-KEY-USE-OPENSSL-RAND-HEX-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Admin Account - CHANGE THESE IN PRODUCTION
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE-THIS-TO-SECURE-PASSWORD
ALLOW_USER_REGISTRATION=true

# ==================== MONITORING (OPTIONAL) ====================
# Add your monitoring service API keys
# SENTRY_DSN=https://your-sentry-dsn
# LOGDNA_KEY=your-logdna-key
